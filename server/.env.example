# Alumni Management System Environment Configuration
# Copy this file to .env and update the values

# Application Settings
APP_NAME="Alumni Management System"
APP_URL=http://localhost
APP_DEBUG=true

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=alumni_system
DB_USERNAME=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-at-least-32-characters
JWT_EXPIRY=30  # days

# Email Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@alumni.edu
MAIL_FROM_NAME="Alumni System"

# Google OAuth (Firebase)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# File Upload Settings
UPLOAD_MAX_SIZE=5242880  # 5MB in bytes
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# Security
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000
SESSION_LIFETIME=120  # minutes

# Points System Configuration
POINTS_PROFILE_COMPLETE=50
POINTS_FIRST_LOGIN=10
POINTS_PROFILE_UPDATE=5
POINTS_REFERRAL=25
POINTS_EVENT_DEFAULT=20

# Badge Levels (minimum points required)
BADGE_BRONZE=0
BADGE_SILVER=100
BADGE_GOLD=500
BADGE_PLATINUM=1000
BADGE_DIAMOND=5000
