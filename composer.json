{
  "name": "alumni/management-system",
  "description": "Alumni Management System with PHP Backend",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.0",
    "phpmailer/phpmailer": "^6.9",
    "firebase/php-jwt": "^6.11",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "giorgiosironi/eris": "^1.1",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "server/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t server server/index.php",
    "test": "phpunit tests"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "audit": {
      "ignore": [
        "PKSA-y2cr-5h3j-g3ys"
      ]
    }
  }
}
