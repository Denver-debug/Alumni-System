# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf

# Scripts
*.sh text eol=lf
*.bat text eol=crlf

# Documentation
*.txt text eol=lf
*.markdown text eol=lf

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.tar binary
*.gz binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Exclude files from export
.gitattributes export-ignore
.gitignore export-ignore
.kiro/ export-ignore
.vscode/ export-ignore
